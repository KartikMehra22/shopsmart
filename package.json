{
  "name": "shopsmart-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "setup": "pnpm install && pnpm -C server install && pnpm -C client install",
    "server": "pnpm -C server dev",
    "client": "pnpm -C client dev",
    "dev": "pnpm server & pnpm client",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:clean": "docker system prune -f",

    "lint": "npm run lint --prefix client && npm run lint --prefix server",
    "test": "npm run test --prefix client -- --run && npm run test --prefix server",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1"
  }
}
